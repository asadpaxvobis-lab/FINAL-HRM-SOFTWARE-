{
  "name": "hrm-erp",
  "version": "0.1.0",
  "private": true,
  "description": "ERP HRM + Payroll System - Industry 4.0 (Pakistan)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "pnpm --filter @hrm/web dev",
    "build:web": "pnpm --filter @hrm/web build",
    "dev:api": "dotnet run --project apps/api/Hrm.Api.csproj",
    "build:api": "dotnet build apps/api/Hrm.Api.csproj",
    "dev:agent": "dotnet run --project apps/agent/Hrm.Agent.csproj",
    "build:agent": "dotnet build apps/agent/Hrm.Agent.csproj"
  },
  "packageManager": "npm@10.0.0",
  "engines": {
    "node": ">=20"
  }
}
